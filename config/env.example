# ohlryn-monitor 시크릿 템플릿 — 레포 루트에 .env_monitor 등으로 복사해 사용 (.env*는 gitignore)
# 알림만 쓰면 텔레그램 두 줄이면 충분. 각 config의 env/alert_env 필드가 이 파일 경로를 가리킴.

# 텔레그램 (필수 — 알림 수신)
TELEGRAM_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# 거래소 (pnl_watch용 — 읽기 전용 권한이면 충분)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# 봇 API 인증 (health_check용 — 봇 웹서버의 Basic Auth)
WEB_USERNAME=
WEB_PASSWORD=
